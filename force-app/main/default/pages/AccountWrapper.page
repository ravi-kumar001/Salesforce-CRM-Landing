<apex:page controller="AccountWrapperController">
    <apex:form >
        <apex:pageBlock title="Select Accounts">
            <apex:pageBlockButtons >
                <apex:commandButton value="Process Selected" />
            </apex:pageBlockButtons>
            
            <apex:pageBlockTable value="{!wrapAccountList}" var="item">
                <apex:column headerValue="Select">
                    <apex:inputCheckbox value="{!item.isSelected}" />
                </apex:column>
                <apex:column value="{!item.acc.Name}" />
                <apex:column value="{!item.acc.Phone}" />
                <apex:column value="{!item.acc.Industry}" />
            </apex:pageBlockTable>
        </apex:pageBlock>
    </apex:form>
</apex:page>