<apex:page controller="Jan9VfpClass">
    <div style="width:900px;margin:auto;border:2px solid #000;font-family:Arial;">
        
        <div style="background: orange;padding:10px;text-align:center;">
            <h1 style="margin:0;color: black; font-size : 40px;">PROFORMA INVOICE</h1>
        </div>

        <div style="text-align:center;margin:5px 0;">
            <h3 style="font-size: 20px">Enter Your Company Name Here</h3>
        </div>

        <apex:pageBlock >
            <apex:pageBlockSection columns="2">
                <apex:pageBlockSectionItem >
                    <b>Company Phone: {!oppObj.Account.Phone}</b>
                </apex:pageBlockSectionItem>
                <apex:pageBlockSectionItem >
                    <b>Company Street Address: {!oppObj.Account.BillingStreet}</b>
                </apex:pageBlockSectionItem>

                <apex:pageBlockSectionItem >
                    <b>Company Email: {!oppObj.Owner.Email}</b>
                </apex:pageBlockSectionItem>
                <apex:pageBlockSectionItem >
                    <b>City, Dist., State : {!oppObj.Account.BillingCity}, {!oppObj.Account.BillingState}, {!oppObj.Account.BillingCountry} </b>
                </apex:pageBlockSectionItem>

                <apex:pageBlockSectionItem >
                    <b>Company Website: {!oppObj.Account.Website}</b>
                </apex:pageBlockSectionItem>
                <apex:pageBlockSectionItem >
                    <b>Pin Code {!oppObj.Account.BillingPostalCode}</b>
                </apex:pageBlockSectionItem>
            </apex:pageBlockSection>
        </apex:pageBlock>

        <div style="border-bottom:1px solid #000;padding:5px;text-align:center;">
            <b>BILLED TO:</b>
        </div>

        <table width="100%" border="1" cellspacing="0" cellpadding="6">
            <tr>
                <td width="35%">
                    <b>Invoice Number: {!oppObj.OrderNumber__c}</b><br/>
                    <b>Date Issued: 15 December 2021 </b> <br/>
					<b>Due Date: 27 December 2021 </b> <br/>
                    <b>Customer Email: {!oppObj.Owner.Email} </b> <br/>
                </td>
                <td width="40%">
                    <b>Name: {!oppObj.name}</b><br/>
                    <b>Street Address: {!oppObj.Account.BillingStreet}</b><br/>
                    <b>City, Dist., State : {!oppObj.Account.BillingCity}, {!oppObj.Account.BillingState}, {!oppObj.Account.BillingCountry} </b><br/>
                    <b>Phone: {!oppObj.Owner.Phone} </b>
                </td>
                <td width="25%" style="background:orange;text-align:center;">
                    <b>ESTIMATE TOTAL</b><br/><br/>
                    <span style="font-size:28px;">₹ {!finalTotal}</span>
                </td>
            </tr>
        </table>

        <div style="border-top:1px solid #000;border-bottom:1px solid #000;text-align:center;padding:5px;">
            <b>PRODUCTS</b>
        </div>

        <apex:pageBlock >
            <apex:pageBlockTable value="{!oppObj.OpportunityLineItems}" var="oppLI">
                <apex:column headerValue="Quantity" value="{!oppLI.Quantity}"></apex:column>
                <apex:column headerValue="Description">{!oppLI.PricebookEntry.Product2.Name}</apex:column>
                <apex:column headerValue="Unit Price">₹ {!oppLI.UnitPrice}</apex:column>
                <apex:column headerValue="Amount">₹ {!oppLI.TotalPrice}</apex:column>
            </apex:pageBlockTable>
        </apex:pageBlock>

        <apex:pageBlock >
            <apex:pageBlockSection columns="2" showHeader="false">
                <apex:pageBlockSectionItem >
                    AMOUNT IN WORDS: <b>FIFTEEN HUNDRED AND ONE RUPEES ONLY</b>
                </apex:pageBlockSectionItem>

                <apex:pageBlockSectionItem >
                    <table width="100%" border="1" cellspacing="0" cellpadding="5">
                        <tr><td>Sub total</td><td align="right">₹ {!subTotal}</td></tr>
                        <tr><td>Discount %</td><td align="right">5%</td></tr>
                        <tr><td>Discount</td><td align="right">₹ {!discountAmount}</td></tr>
                        <tr><td>Shipping charges</td><td align="right">₹ 200.00</td></tr>
                        <tr><td>Tax Rate (%)</td><td align="right">12%</td></tr>
                        <tr><td>Tax amount</td><td align="right">₹ 160.80</td></tr>
                        <tr style="background:oragne;">
                            <td><b>TOTAL</b></td>
                            <td align="right"><b>₹ {!finalTotal}</b></td>
                        </tr>
                    </table>
                </apex:pageBlockSectionItem>
            </apex:pageBlockSection>
        </apex:pageBlock>

        <apex:pageBlock >
            <apex:pageBlockSection columns="1" showHeader="false">
                <apex:pageBlockSectionItem >
                    Payment is due within the following number of days: <b>12</b>
                </apex:pageBlockSectionItem>
                <apex:pageBlockSectionItem >
                    Comments or Special Instructions:
                </apex:pageBlockSectionItem>
            </apex:pageBlockSection>
        </apex:pageBlock>

    </div>
</apex:page>