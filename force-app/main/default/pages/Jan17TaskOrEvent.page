<apex:page controller="Jan17TaskOrEvent">
    <div style="width:90%; height: 90%; margin: auto; margin-top: 30px;">
        <div style="padding: 2px 16px;">
            <h1 style="margin-bottom: 0; font-size: 20px;"><b>Task/Event Assingnment</b></h1>
            <div style="padding-bottom: 15px;">
                <apex:form >
                	<apex:pageBlock >                      
                    	 <div style="display:flex; align-items: center; justify-content: center;" >
                             
                            <apex:actionRegion >
                             	<apex:selectRadio value="{!selectedOption}">
            						<apex:actionSupport event="onchange" rerender="inputSection" />
                                    <apex:selectOption itemValue="task" itemLabel="Task" />
                                    <apex:selectOption itemValue="event" itemLabel="Event" />
      					  </apex:selectRadio>
                             </apex:actionRegion>
                        </div>
                        
                        <apex:outputPanel id="inputSection" layout="block" style="width: 80%">
               				 <apex:pageBlock >
                    
                   	 <apex:outputPanel id="form1_panel" rendered="{!selectedOption == 'task'}">
                        <apex:pageBlockSection columns="1">
                            <apex:inputField value="{!currTask.Subject}"/>
                            <apex:inputField value="{!currTask.WhatId}"/>
                            <apex:inputField value="{!currTask.WhoId}"/>
                            <apex:inputField value="{!currTask.ActivityDate}"/>
                            <apex:inputField value="{!currTask.Status}"/>
                            <apex:inputField value="{!currTask.Priority}"/>
                            <apex:inputField value="{!currTask.OwnerId}"/>
                        </apex:pageBlockSection>
                    </apex:outputPanel>

                    <apex:outputPanel id="form2_panel" rendered="{!selectedOption == 'event'}">
                        <apex:pageBlockSection columns="1">
                            <apex:inputField value="{!currEvent.Subject}"/>
                            <apex:inputField value="{!currEvent.WhatId}"/>
                            <apex:inputField value="{!currEvent.WhoId}"/>
                            <apex:inputField value="{!currEvent.StartDateTime}"/>
                            <apex:inputField value="{!currEvent.EndDateTime}"/>
                            <apex:inputField value="{!currEvent.OwnerId}"/>
                        </apex:pageBlockSection>
                    </apex:outputPanel>
                    
                        <div style="display: flex; justify-content: flex-end; margin-right: 300px">
                            <apex:commandButton value="Assign" action="{!assignHandler}"  />
                                 </div>
                </apex:pageBlock>
           			    </apex:outputPanel>                        
                    </apex:pageBlock>
                </apex:form>
            </div>
        </div>
    </div>
</apex:page>