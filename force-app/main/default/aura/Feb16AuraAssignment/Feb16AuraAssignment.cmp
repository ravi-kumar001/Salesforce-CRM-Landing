<aura:component controller="Feb16AuraAssignment" 
                implements="flexipage:availableForRecordHome,force:hasRecordId" access="global">
    <aura:attribute name="title" type="String" default="Related List" />
    <aura:attribute name="records" type="List" />
    <aura:attribute name="bgColor" type="String" default="white" />
    <aura:attribute name="viewMode" type="String" default="table" />
    
    <aura:handler name="init" value="{!this}" action="{!c.doInit}" />

    <div style="{! 'background-color:' + v.bgColor + '; padding:10px; border-radius:5px;' }">
        <lightning:card title="{!v.title}" iconName="standard:groups">
            <aura:set attribute="actions">
                <lightning:button label="Refresh" onclick="{!c.doInit}" />
                <lightning:button label="Toggle View" onclick="{!c.toggleView}" />
            </aura:set>

            <div class="{! v.viewMode == 'table' ? 'slds-show' : 'slds-hide' }">
                <table class="slds-table slds-table_bordered">
                    <thead><tr><th>Name</th><th>Details</th></tr></thead>
                    <tbody>
                        <aura:iteration items="{!v.records}" var="rec">
                            <tr>
                                <td>{!rec.Name}</td>
                                <td aura:id="badgeContainer">
                                </td>
                            </tr>
                        </aura:iteration>
                    </tbody>
                </table>
            </div>
        </lightning:card>
    </div>
</aura:component>