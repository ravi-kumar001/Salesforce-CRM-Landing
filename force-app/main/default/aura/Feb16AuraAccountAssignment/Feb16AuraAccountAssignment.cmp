<aura:component implements="flexipage:availableForRecordHome,force:hasRecordId" access="global" controller="Feb16AuraAccountAssignmentHandler" >
    <p>Assignment For Account And Contact</p>
    <aura:attribute name="objectName" type="String" default="Account"></aura:attribute>
    <aura:handler name="init" value="{!this}" action="{!c.doInit}" />
    <aura:attribute name="fields" type="List" />
    <aura:attribute name="records" type="List" />
    <lightning:card>
        <lightning:datatable
           keyField="Id"
           columns="{!v.fields}"
           data="{!v.records}"
        />
    </lightning:card>
</aura:component>